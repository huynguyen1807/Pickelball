{
    "name": "pickleball-server",
    "version": "1.0.0",
    "type": "commonjs",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only index.ts",
        "dev:nodemon": "nodemon --exec ts-node index.ts",
        "migrate": "ts-node database/migrate.ts",
        "migrate:payment-status": "ts-node database/run-migration-payment-status.ts"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "mssql": "^10.0.2",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.1",
        "socket.io": "^4.7.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/ms": "^2.1.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.3.0",
        "@types/nodemailer": "^7.0.11",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    }
}
